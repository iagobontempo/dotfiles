include-file = ~/.config/polybar/colors.ini

[settings]
; Reload upon receiving XCB_RANDR_SCREEN_CHANGE_NOTIFY events
screenchange-reload = false
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[global/wm]
margin-top = 0
margin-bottom = 0

[bar/main]
monitor = ${env:MONITOR}
width = 100%
height = 20
offset-x = 0%
offset-y = 0%
radius = 0.0
fixed-center = true

underline-size = 1
underline-color = ${colors.foreground}

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 2
line-color = #f00

border-size = 4
border-color = ${colors.alpha}

padding-left = 0
padding-right = 0

module-margin-left = 1
module-margin-right = 1

font-0 = "Iosevka Nerd Font:pixelsize=10;2"
font-1 = "Iosevka Nerd Font:pixelsize=13;2"

modules-left = bspwm
modules-center = date
modules-right = bluetooth G733-mic-volume G733-headset-battery pulseaudio memory cpu battery tray powermenu

;wm-restack = bspwm
;wm-restack = i3

;override-redirect = true

;scroll-up = bspwm-desknext
;scroll-down = bspwm-deskprev

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

[module/tray]
type = internal/tray
format-margin = 8px
tray-spacing = 8px

[module/xwindow]
type = internal/xwindow
label = %title:0:30:...%

[module/bspwm]
type = internal/bspwm

;pin-workspaces = true

label-focused = %name%
label-focused-background = ${colors.secondary}
label-focused-foreground = ${colors.foreground}
label-focused-underline= ${colors.foreground}
label-focused-padding = 2

label-occupied = %name%
label-occupied-padding = 2
label-occupied-foreground = ${colors.secondary}

label-urgent = %name%!
label-urgent-background = #CC6666
label-urgent-padding = 2

label-empty = %name%
label-empty-foreground = ${colors.foreground-alt}
label-empty-padding = 2

; Separator in between workspaces
; label-separator = |

[module/G733-headset-battery]
;https://aur.archlinux.org/headsetcontrol.git
type = custom/script
exec = sh $HOME/.config/polybar/scripts/headset-battery.sh
exec-if = sh $HOME/.config/polybar/scripts/check-g733-connected.sh
interval = 5
label=%output%
format-prefix = "G733 Ôüć "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.secondary}

[module/G733-mic-volume]
type = custom/script
exec = sh $HOME/.config/polybar/scripts/show-headset-mic.sh
exec-if = sh $HOME/.config/polybar/scripts/check-g733-connected.sh
interval = 5
label=%output%
format-prefix = "G733 ÔĄį "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.secondary}
click-left = amixer -c 1 set Mic 100

; Must have RUST-SCRIPTS installed
[module/bluetooth]
type = custom/script
exec = echo "Ôäď" 
format-prefix = ""
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.secondary}
click-left = $HOME/.config/polybar/scripts/bluetooth.rs
click-right = $HOME/.config/polybar/scripts/bluetooth.rs

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "ÓÉź "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.secondary}
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "Ô°ö "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.secondary}
label = %mb_used%

[module/date]
type = internal/date
interval = 5

time = %H:%M %p
time-alt =  %a, %d %b %Y

format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.secondary}

label = %time%

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume> <bar-volume>
label-volume = VOL %percentage%%
label-volume-foreground = ${root.foreground}

label-muted = ÔĎ¶ sound muted
label-muted-foreground = #666

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ‚ĒÄ
bar-volume-fill-font = 2
bar-volume-empty = ‚ĒÄ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/alsa]
type = internal/alsa

format-volume = <label-volume> <bar-volume>
label-volume = VOL %percentage%%
label-volume-foreground = ${root.foreground}

format-muted-prefix = "ÔĎ¶ "
format-muted-foreground = ${colors.foreground-alt}
label-muted = sound muted

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ‚ĒÄ
bar-volume-fill-font = 2
bar-volume-empty = ‚ĒÄ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-charging = <animation-charging> <label-charging>
format-charging-underline = ${colors.secondary}

format-discharging = <animation-discharging> <label-discharging>
format-discharging-underline = ${self.format-charging-underline}

format-full-prefix = "ÔČÄ  "
format-full-prefix-foreground = ${colors.foreground-alt}
format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = "ÔČÉ "
ramp-capacity-1 = "ÔČā "
ramp-capacity-2 = "ÔČĀ "
ramp-capacity-foreground = ${colors.foreground-alt}

animation-charging-0 = "ÔČÉ " 
animation-charging-1 = "ÔČā "
animation-charging-2 = "ÔČĀ " 
animation-charging-foreground = ${colors.foreground-alt}
animation-charging-framerate = 750

animation-discharging-0 = "ÔČĀ "
animation-discharging-1 = "ÔČā "
animation-discharging-2 = "ÔČÉ "
animation-discharging-foreground = ${colors.foreground-alt}
animation-discharging-framerate = 750

[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 2
format-padding = 2

label-open = ÔÄĎ 
label-open-foreground = #FF0000
label-close = cancel
label-close-foreground = #FF0000
label-separator = |
label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = reboot

menu-2-0 = power off
menu-2-0-exec = poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

